# ============================================================================
# Student Result Management System — Environment Variables
# ============================================================================
# Copy this file to .env for local development:
#   cp .env.example .env
# Then fill in real values below. Never commit your actual .env file.
# ============================================================================

# ---- Database (Neon Postgres via Vercel) ----------------------------------
# Vercel's Postgres storage is powered by Neon. After creating a Postgres
# database from the Vercel dashboard (Storage tab) and connecting it to this
# project, Vercel auto-populates these variables for you — you can copy them
# from Project Settings → Environment Variables, or run `vercel env pull`.
#
# DATABASE_URL   -> pooled connection (used by the app at runtime)
# DIRECT_URL     -> direct/unpooled connection (used only by Prisma Migrate)
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-example.region.aws.neon.tech/dbname?sslmode=require"

# ---- NextAuth / Auth.js ----------------------------------------------------
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-byte-base64-string"

# Only needed for local development. In production on Vercel this is
# detected automatically from the deployment URL and does not need to be set.
# AUTH_URL="http://localhost:3000"

# ---- App ---------------------------------------------------------------
NODE_ENV="development"
